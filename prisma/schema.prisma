generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  PICKSTER
  BJ
  ADMIN
  SUPERADMIN
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  password     String
  nickname     String    @unique
  role         UserRole  @default(USER)
  points       Int       @default(0)
  exp          Int       @default(0)
  name         String?
  phone        String?
  phoneVerified Boolean  @default(false)
  email        String?   @unique
  referredBy   String?
  birthDate    DateTime? @db.Date    // 생년월일 (1회 등록 후 잠금)
  lastDailyLoginAt    DateTime?       // 매일 첫 로그인 보상 마지막 지급 시각 (KST 일자 비교)
  lastBirthdayBonusYear Int?          // 생일 보상 마지막 지급 연도
  eventStreak  Int       @default(0)  // 이벤트 정답 연승 카운트
  eventBestStreak Int    @default(0)  // 이벤트 최고 연승 기록
  chatRewardPoints Int   @default(0)  // 오늘 채팅으로 적립된 포인트 (KST 일자 리셋)
  chatRewardExp    Int   @default(0)  // 오늘 채팅으로 적립된 경험치
  chatRewardDate   DateTime? @db.Date // 채팅 보상 누적 기준 일자
  analysisRewardCount Int @default(0) // 오늘 분석글 보상 받은 횟수
  analysisRewardDate  DateTime? @db.Date // 분석글 보상 기준 일자
  isActive     Boolean   @default(true)
  // 관리자 메모 — 비활성화 사유, 특이사항, 다중계정 의심 등 기록
  adminMemo    String    @default("") @db.Text
  // 휴면 회원 식별용
  lastLoginAt  DateTime?
  // 이 시각 이전 발급된 JWT는 무효 (강제 로그아웃용)
  sessionInvalidAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pointLogs       PointLog[]
  attendances     Attendance[]
  pointExchanges  PointExchange[]
  posts           Post[]
  comments        Comment[]
  chatMessages    ChatMessage[]
  analysisPosts   AnalysisPost[]    @relation("UserAnalysisPosts")
  picksterProfile PicksterProfile?
  accessLogs      AccessLog[]
  partnerLikes    PartnerLike[]
  bjProfile       BjProfile?
  bjChatMessages  BjChatMessage[]
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int?
  nickname  String
  role      UserRole @default(USER)
  level     Int      @default(0)
  text      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

enum PointType {
  EARN
  DEDUCT
  EXCHANGE
}

model PointLog {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      PointType
  amount    Int
  reason    String
  balance   Int?      // 적립/차감 후 잔액 (신규 로그부터 기록)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime @db.Date
  points    Int
  streak    Int      @default(1)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

enum ExchangeStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

model PointExchange {
  id          Int            @id @default(autoincrement())
  userId      Int
  amount      Int
  status      ExchangeStatus @default(PENDING)
  productName String
  memo        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id])
}

model Board {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  slug          String   @unique
  readLevel     UserRole @default(USER)
  writeLevel    UserRole @default(USER)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  posts         Post[]
}

model Post {
  id          Int      @id @default(autoincrement())
  boardId     Int
  authorId    Int
  title       String
  content     String   @db.Text
  isPinned    Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board       Board    @relation(fields: [boardId], references: [id])
  author      User     @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
}

// ─── 레벨 설정 ─────────────────────
model LevelSetting {
  id        Int      @id @default(autoincrement())
  level     Int      @unique
  name      String   @default("")    // 레벨 이름
  requiredExp Int    @default(0)      // 필요 경험치
  badge     String   @default("")    // 뱃지 이모지/텍스트
  color     String   @default("")    // 레벨 색상 (hex, e.g. #3b82f6)
  bgColor   String   @default("")    // 레벨 배경색 (hex, e.g. #eff6ff)
  birthdayBonusEnabled Boolean @default(false)  // 이 레벨에서 생일 보상 지급 가능
  updatedAt DateTime @updatedAt
}

model AttendanceSetting {
  id        Int      @id @default(autoincrement())
  dayNumber Int      @unique
  points    Int
  updatedAt DateTime @updatedAt
}

// ─── 제휴업체 ─────────────────────
model Partner {
  id        Int      @id @default(autoincrement())
  name      String
  category  String   @default("공식제휴")
  badge     String   @default("공식제휴")
  desc      String
  img       String   @default("/business.png")
  thumb     String   @default("")
  likes     Int      @default(0)
  views     Int      @default(0)
  content   String   @db.Text
  contact   String   @default("1234")
  site      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerLikes PartnerLike[]
}

// ─── 제휴업체 좋아요 ─────────────────────
model PartnerLike {
  id        Int      @id @default(autoincrement())
  partnerId Int
  userId    Int
  createdAt DateTime @default(now())

  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([partnerId, userId])
}

// ─── 포인트 상품 ─────────────────────
model PointProduct {
  id        Int      @id @default(autoincrement())
  name      String
  price     Int
  thumb     String   @default("")
  category  String   @default("spon")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 이벤트 게시판 ─────────────────────
model EventBoard {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  author    String   @default("라이브TV")
  isPinned  Boolean  @default(false)
  viewCount Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 이벤트매치 ─────────────────────
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  bannerImg   String   @default("")
  bottomImg   String   @default("")
  teamA       String
  teamB       String
  betType     String   @default("승패")     // 승패 / 승무패 / 핸디캡 / 언더오버
  betLine     String   @default("")        // 핸디캡/언더오버 기준점 (예: "-1.5", "2.5")
  reward      String   @default("10,000원 포인트")   // 사용자 노출용 보상 문구
  rewardPoints Int?                            // 수동 보상 모드 — NULL이면 activityReward 기본값 사용
  deadline    DateTime
  isActive    Boolean  @default(true)
  allowDraw   Boolean  @default(false)  // 무승부 베팅 옵션 (3-way: A/DRAW/B) — betType=승무패 시 true
  viewCount   Int      @default(0)
  winnerSide  String?              // 정산 결과: "A" / "B" / "DRAW" (NULL=미정산)
  settledAt   DateTime?            // 정산 완료 시각
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  votes       EventVote[]
}

model EventVote {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  pick      String
  isCorrect Boolean?            // 정산 결과 (NULL=미정산, true=정답, false=오답/무효)
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ─── 이벤트 연승 보상 단계 (가변) ─────────────────────
model EventStreakSetting {
  id        Int      @id @default(autoincrement())
  threshold Int      @unique     // N연승 (3, 5, 10 등)
  points    Int      @default(0)
  exp       Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── 공지사항 ─────────────────────
model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  author    String   @default("라이브TV")
  isPinned  Boolean  @default(false)
  viewCount Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 활동 보상 설정 ─────────────────────
model ActivityReward {
  id          Int      @id @default(autoincrement())
  activityKey String   @unique   // signup, attendance, chat, event_join, event_correct, analysis_write, referral, post_write, comment_write
  label       String             // 표시명
  points      Int      @default(0)
  exp         Int      @default(0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ─── 분석 포스트 ─────────────────────
enum AnalysisResult {
  PENDING
  WIN
  LOSS
  CANCEL
}

model AnalysisPost {
  id          Int             @id @default(autoincrement())
  authorId    Int
  sport       String          // soccer, baseball, basketball 등
  league      String          // EPL, KBO, NBA 등
  matchTime   DateTime
  homeTeam    String
  homeLogo    String          @default("")
  homeRecord  String          @default("")
  awayTeam    String
  awayLogo    String          @default("")
  awayRecord  String          @default("")
  title       String
  content     String          @db.Text
  prediction  String          // "맨체스터 시티 우세"
  odds        String          @default("")
  result      AnalysisResult  @default(PENDING)
  isPublic    Boolean         @default(true)
  isPremium   Boolean         @default(false)
  viewCount   Int             @default(0)
  likeCount   Int             @default(0)
  isAutoGenerated Boolean      @default(false)
  matchKey    String          @default("")
  isDraft     Boolean         @default(false)
  // ── 가짜 조회수 부풀리기 (관리자만 설정) ─────────────
  fakeViewsEnabled    Boolean   @default(false)
  fakeViewsTarget     Int       @default(0)    // 도달 목표 boost 값
  fakeViewsRampHours  Int       @default(24)   // 0 → target까지 ramp-up 시간 (시간 단위)
  fakeViewsStartAt    DateTime?                // 부풀리기 시작 시각 (관리자가 enable 시 자동 set)
  fakeViewsManualSet  Boolean   @default(false) // true면 개별 설정, false면 전역 설정 fallback
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  author      User            @relation("UserAnalysisPosts", fields: [authorId], references: [id])

  @@index([matchKey])
}

// ─── 자동 분석 설정 ─────────────────────
model AutoAnalysisSetting {
  id            Int      @id @default(1)
  isEnabled     Boolean  @default(false)
  targetLeagues String   @default("[\"EPL\",\"라리가\",\"세리에A\",\"분데스리가\",\"MLB\",\"NBA\"]") @db.Text
  topN          Int      @default(4)
  cronHour      Int      @default(8)
  cronMinute    Int      @default(0)
  aiModel       String   @default("gpt")     // claude / gpt / gemini
  autoPublish   Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

// ─── 픽스터 프로필 ─────────────────────
model PicksterProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  avatar      String   @default("")
  sport       String   // 전문 종목
  intro       String   @db.Text
  tier        String   @default("브론즈")
  monthlyFee  Int      @default(0)
  isApproved  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

// ─── 팀 로고 ─────────────────────
model TeamLogo {
  id        Int      @id @default(autoincrement())
  nameKr    String                  // 한글 팀명 (API에서 오는 이름) — sport와 함께 unique
  nameEn    String   @default("")   // 영문 팀명
  sport     String   @default("")   // soccer, baseball, basketball 등
  league    String   @default("")   // KBO, NPB, EPL 등
  logoPath  String                  // /team-logos/LG.png
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nameKr, sport])
}

// ─── 유튜브 하이라이트 누적 저장 ─────────────────────
model YouTubeHighlight {
  videoId      String   @id            // YouTube 영상 ID
  title        String
  channel      String                  // 채널명 (표시용)
  channelId    String                  // YouTube 채널 ID
  thumbnail    String   @default("")
  publishedAt  DateTime                // 영상 업로드 시각
  category     String   @default("etc") // soccer, baseball, basketball ...
  league       String   @default("")
  homeTeam     String   @default("")
  awayTeam     String   @default("")
  isHighlight  Boolean  @default(false)
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@index([category, publishedAt(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
}

// ─── 사이트 설정 ─────────────────────
model SiteSetting {
  id                  Int      @id @default(1)
  showLogoBroadcast   Boolean  @default(true)   // 중계 페이지 팀 로고
  showLogoMain        Boolean  @default(true)   // 메인 페이지 팀 로고
  showLogoAnalysis    Boolean  @default(true)   // 분석 페이지 팀 로고
  showLogoYoutube     Boolean  @default(true)   // 유튜브 하이라이트 팀 로고
  anthropicApiKey     String   @default("")    // Anthropic API 키
  anthropicEnabled    Boolean  @default(false) // Claude 버튼 노출
  openaiApiKey        String   @default("")    // OpenAI API 키
  openaiEnabled       Boolean  @default(false) // GPT 버튼 노출
  geminiApiKey        String   @default("")    // Gemini API 키
  geminiEnabled       Boolean  @default(false) // Gemini 버튼 노출
  gnewsApiKey         String   @default("")    // GNews API 키
  youtubeApiKey       String   @default("")    // YouTube Data API 키
  levelDisplayMode    String   @default("badge") // badge/emoji/none
  // ── SEO ──
  seoTitle             String   @default("라이브Felix - 스포츠 중계 분석 커뮤니티")
  seoDescription       String   @default("축구, 야구, 농구, 배구, UFC, LOL 무료 스포츠 중계 및 분석 플랫폼.") @db.Text
  seoKeywords          String   @default("스포츠중계,무료중계,EPL,NBA,KBO,UFC,LOL")
  seoOgImage           String   @default("")
  seoNaverVerification String   @default("")
  seoGoogleVerification String  @default("")
  seoGaId              String   @default("")
  seoFavicon           String   @default("")
  seoRobotsTxt         String   @default("User-agent: *\nAllow: /\nSitemap: https://livefelix.com/sitemap.xml") @db.Text
  noticeTicker         String   @default("라이브Felix에서 EPL · 챔피언스리그 · NBA · KBO · UFC · LOL 무료 고화질 중계를 즐기세요! 매일 출석체크로 포인트를 적립하고 다양한 이벤트에 참여하세요.") @db.Text
  adminAlarmSound      String   @default("beep")  // beep/bell/chime/ping/alert/drop
  // ── 가짜 공개채팅 시청자 부풀리기 ──
  fakeViewersChatEnabled Boolean @default(false)
  fakeViewersChatMin     Int     @default(0)
  fakeViewersChatMax     Int     @default(0)
  // ── 분석글 가짜 조회수 전역 default (개별 글 설정이 없을 때 적용) ──
  fakeViewsAnalysisEnabled    Boolean @default(false)
  fakeViewsAnalysisTargetMin  Int     @default(0)
  fakeViewsAnalysisTargetMax  Int     @default(0)
  fakeViewsAnalysisRampHours  Int     @default(24)
  // ── 이벤트 자동 마감 (deadline 도달 시 isActive=false 자동 처리) ──
  autoCloseEventsEnabled      Boolean @default(true)
  // ── 가입 시 추가 정보 수집 ──
  collectBirthDateOnSignup Boolean @default(false)
  collectPhoneOnSignup     Boolean @default(false)
  // ── 생일 보상 ──
  birthdayBonusEnabled Boolean @default(false)
  birthdayMinLevel     Int     @default(3)
  // ── 포인트 교환 락업 ──
  exchangeMinLevel     Int     @default(3)
  exchangeLockEnabled  Boolean @default(true)
  // ── 일반 유저 분석글 ──
  allowUserAnalysis        Boolean @default(true)
  analysisRewardDailyLimit Int     @default(1)   // 0=무제한
  // ── 채팅 보상 캡 ──
  chatRewardDailyPointCap   Int     @default(100)  // 0=무제한
  chatRewardDailyExpCap     Int     @default(100)
  chatMinLength             Int     @default(5)
  chatMinLengthEnabled      Boolean @default(true)
  chatDuplicateBlockEnabled Boolean @default(true)
  // ── 텔레그램 알림 ──
  telegramBotToken          String  @default("")
  telegramSubscribePasscode String  @default("")  // /start 후 입력받을 구독 비밀번호
  telegramNotifyEnabled     Boolean @default(false)
  updatedAt            DateTime @updatedAt
}

// 텔레그램 알림 구독자 (비밀번호 인증 후 등록됨)
model TelegramSubscriber {
  chatId       String   @id           // Telegram chat ID (string으로 저장 — 음수/BigInt 안전)
  username     String   @default("")  // @username
  firstName    String   @default("")
  subscribedAt DateTime @default(now())
}

// ─── 배너 관리 ─────────────────────
model Banner {
  id        Int      @id @default(autoincrement())
  name      String   @default("")       // 배너 이름 (관리용)
  imageUrl  String   @default("")       // 이미지 경로
  linkUrl   String   @default("")       // 클릭 시 이동 URL
  position  String   @default("left_top") // left_top, left_bottom, right_top, right_bottom
  sort      Int      @default(0)        // 정렬 순서
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 팝업 관리 ─────────────────────
model Popup {
  id          Int      @id @default(autoincrement())
  name        String   @default("")       // 팝업 이름 (관리용)
  imageUrl    String   @default("")       // 이미지 경로
  linkUrl     String   @default("")       // 클릭 시 이동 URL
  width       Int      @default(400)      // 팝업 너비 (px)
  height      Int      @default(500)      // 팝업 높이 (px)
  posX        Int      @default(100)      // X 위치
  posY        Int      @default(100)      // Y 위치
  hideToday   Boolean  @default(true)     // 오늘 하루 안보기 버튼
  isActive    Boolean  @default(true)
  startDate   DateTime?                   // 노출 시작일
  endDate     DateTime?                   // 노출 종료일
  sort        Int      @default(0)        // 정렬 순서
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── 접속/로그인 기록 ─────────────────────
model AccessLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     // 로그인 유저 (비로그인은 null)
  type        String   @default("visit") // visit, login
  ip          String   @default("")
  mac         String   @default("") // 브라우저에서 MAC 수집 불가, fingerprint 대체
  userAgent   String   @default("") @db.Text
  device      String   @default("") // desktop, mobile, tablet
  browser     String   @default("")
  os          String   @default("")
  referer     String   @default("") // 접속경로 (이전 URL)
  path        String   @default("") // 접속한 페이지
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([ip])
}

// ─── 회원가입 선택필드 설정 (관리자) ─────────────────────
model RegistrationSetting {
  id              Int      @id @default(1)
  requireName     Boolean  @default(false)
  requirePhone    Boolean  @default(false)
  requireEmail    Boolean  @default(false)
  requireBirthDate Boolean @default(false)
  updatedAt       DateTime @updatedAt
}

// ─── BJ 프로필 ─────────────────────
model BjProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  streamKey   String   @unique @default("")
  title       String   @default("방송 제목")
  description String   @default("") @db.Text
  category    String   @default("") // soccer, baseball 등
  thumbnail   String   @default("")
  avatar      String   @default("")     // 프로필 이미지 경로 또는 이모지
  avatarType  String   @default("emoji") // emoji | image
  statusMessage String @default("")    // 방송 상태 메시지
  offlineMsg  String   @default("방송 준비 중입니다. 잠시만 기다려주세요!")
  bannerUrl   String   @default("")     // 가입문의 배너 링크
  bannerText  String   @default("가입문의") // 배너 텍스트
  pinnedMessage String @default("")     // 고정 메시지
  systemMessages String @default("[]") @db.Text // JSON: [{text, intervalMin}]
  isLive      Boolean  @default(false)
  liveStartedAt DateTime? // 방송 시작 시각
  isApproved  Boolean  @default(false)
  isActive    Boolean  @default(true)
  viewCount   Int      @default(0)     // 누적 시청자 (unique IP)
  liveViewers Int      @default(0)     // 현재 실시간 시청자
  // ── 가짜 시청자 부풀리기 (관리자만 설정) ─────────────
  fakeViewersEnabled Boolean @default(false)
  fakeViewersMin     Int     @default(0)
  fakeViewersMax     Int     @default(0)
  fakeViewersRampSec Int     @default(600)  // 방송 시작 후 N초 동안 0 → max로 ramp-up
  // ── 방송 딜레이 (시청자 측 버퍼 latency) ─────────────
  bufferLatency      Float   @default(3.5)  // 1.5(저지연) ~ 8.0(안정) 초
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  chatMessages BjChatMessage[]
  chatBans    BjChatBan[]
  managers    BjChatManager[]
  viewLogs    BjViewLog[]
}

// ─── BJ 시청 기록 (IP 기반 중복 방지) ─────────────────────
model BjViewLog {
  id          Int      @id @default(autoincrement())
  bjProfileId Int
  ip          String
  lastSeen    DateTime @default(now()) // heartbeat 갱신용
  createdAt   DateTime @default(now())

  bjProfile   BjProfile @relation(fields: [bjProfileId], references: [id], onDelete: Cascade)

  @@unique([bjProfileId, ip])
  @@index([bjProfileId, lastSeen])
}

// ─── BJ 채팅 매니저 ─────────────────────
model BjChatManager {
  id          Int      @id @default(autoincrement())
  bjProfileId Int
  userId      Int
  nickname    String   @default("")
  createdAt   DateTime @default(now())

  bjProfile   BjProfile @relation(fields: [bjProfileId], references: [id], onDelete: Cascade)

  @@unique([bjProfileId, userId])
}

// ─── BJ 채팅 차단 ─────────────────────
// 회원 차단: userId set, guestId null
// 비회원 차단: userId=0, guestId set (게스트 식별자는 localStorage 기반)
model BjChatBan {
  id          Int      @id @default(autoincrement())
  bjProfileId Int
  userId      Int      @default(0)
  guestId     String?
  nickname    String   @default("")
  reason      String   @default("")
  createdAt   DateTime @default(now())

  bjProfile   BjProfile @relation(fields: [bjProfileId], references: [id], onDelete: Cascade)

  @@unique([bjProfileId, userId])
  @@unique([bjProfileId, guestId])
}

// ─── BJ 개별 채팅 ─────────────────────
model BjChatMessage {
  id          Int      @id @default(autoincrement())
  bjProfileId Int
  userId      Int?
  nickname    String
  role        UserRole @default(USER)
  level       Int      @default(0)
  text        String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())

  bjProfile   BjProfile @relation(fields: [bjProfileId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])
}

// ─── 관리자 감사 로그 ─────────────────────
model AdminLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  nickname  String   @default("")
  action    String   // 예: "user.role.change", "event.create", "bj.approve"
  target    String   @default("") // 대상 정보 (예: "userId:5", "eventId:3")
  detail    String   @default("") @db.Text // 변경 내용 JSON
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
}

// ─── IP 차단 ─────────────────────
model BannedIp {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  reason    String   @default("")
  bannedBy  String   @default("")
  createdAt DateTime @default(now())

  @@index([ip])
}

// ─── 핸드폰 인증 로그 ─────────────────────
model PhoneVerificationLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  nickname  String   @default("")
  phone     String
  success   Boolean  @default(false)
  type      String   @default("verify") // send / verify
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}
